# Copiez ce fichier en ".env" et remplissez vos vraies valeurs.
# Le fichier .env est ignoré par Git — vos clés ne partent jamais sur GitHub.

# Clé secrète de l'intégration Notion (commence par "ntn_").
NOTION_API_KEY=ntn_votre_cle_ici

# ID de la "source de données" Notion (SDK v5).
# Astuce : c'est l'élément de type "data_source" renvoyé par l'API de recherche,
# PAS l'ID de la page qui contient la base.
NOTION_DATA_SOURCE_ID=votre_id_de_source_ici

# Adresse publique du site (pour le SEO / sitemap). Ex: https://findfi.netlify.app
NEXT_PUBLIC_SITE_URL=https://votre-site.netlify.app
